{
  "name": "merge-pets-2048",
  "description": "Merge Pets 2048 — HTML5 merge game for Yandex Games (Phaser 3 + TypeScript + Vite + Matter.js).",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "tsc --noEmit && vite build --config vite/config.prod.mjs",
    "build-nocheck": "vite build --config vite/config.prod.mjs",
    "preview": "vite preview --config vite/config.prod.mjs --port 8080",
    "typecheck": "tsc --noEmit",
    "zip": "node scripts/build-zip.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "~5.7.2",
    "vite": "^6.3.1"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "terser": "^5.39.0"
  }
}
